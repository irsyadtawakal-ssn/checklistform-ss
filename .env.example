# Salin file ini ke .env dan isi nilainya
# JANGAN commit file .env ke git

# ===== Database =====
DB_HOST=localhost
DB_NAME=ss_operations
DB_USER=db_username
DB_PASS=db_password
DB_CHARSET=utf8mb4

# ===== App =====
APP_ENV=production
APP_URL=https://ops.sukashawarma.com
APP_SECRET=ganti-dengan-random-string-panjang-32-karakter

# ===== Session =====
SESSION_LIFETIME=43200
SESSION_NAME=ss_ops_session

# ===== Upload =====
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=uploads/spv

# ===== Timezone =====
APP_TIMEZONE=Asia/Jakarta
